const APP=Object.freeze({NAME:'Demon Jewellery',TAGLINE:'Brillante Estilo',SPREADSHEET_ID:'15Kd9BGsL6itd05hYyy4yQePSCn0ir5X0wtiWswNuGjI',ADMIN_EMAIL_PROPERTY:'DEMON_JEWELLERY_ADMIN_EMAIL',WHATSAPP_PROPERTY:'DEMON_JEWELLERY_WHATSAPP',CURRENCY:'MXN',TIMEZONE:'America/Mexico_City',SHIPPING_COST:99,FREE_SHIPPING_FROM:1000,SHEETS:Object.freeze({PRODUCTS:'Productos',ORDERS:'Pedidos',CLIENTS:'Clientes',CONFIG:'Configuracion'})});
function getPublicConfig_(){const props=PropertiesService.getScriptProperties();const config=getStoreConfig_();return{appName:config.nombreTienda||APP.NAME,tagline:config.eslogan||APP.TAGLINE,currency:APP.CURRENCY,whatsapp:props.getProperty(APP.WHATSAPP_PROPERTY)||config.whatsapp||'',shippingCost:Number(config.costoEnvio||APP.SHIPPING_COST),freeShippingFrom:Number(config.envioGratisDesde||APP.FREE_SHIPPING_FROM),version:'2.0.0'};}
function getSpreadsheet_(){return SpreadsheetApp.openById(APP.SPREADSHEET_ID);}
function getStoreConfig_(){const sh=getSpreadsheet_().getSheetByName(APP.SHEETS.CONFIG);if(!sh||sh.getLastRow()<2)return{};return sh.getRange(2,1,sh.getLastRow()-1,2).getDisplayValues().reduce((out,row)=>{const key=String(row[0]||'').trim();if(key)out[key]=row[1];return out;},{});}
