function crearPedido(payload){validateOrder_(payload);const ss=getSpreadsheet_(),orders=ss.getSheetByName(APP.SHEETS.ORDERS),productsSheet=ss.getSheetByName(APP.SHEETS.PRODUCTS),lock=LockService.getScriptLock();lock.waitLock(20000);try{const productData=productsSheet.getDataRange().getValues(),headers=productData[0].map(String),indexes=Object.fromEntries(headers.map((h,i)=>[h,i])),byId={};productData.slice(1).forEach((row,offset)=>{const id=String(row[indexes.id]||'').trim();if(id)byId[id]={row,rowNumber:offset+2};});let subtotal=0;const items=payload.items.map(item=>{const record=byId[String(item.id||'').trim()];if(!record||!truthy_(record.row[indexes.activo]))throw new Error('Producto no disponible: '+item.id);const qty=Math.max(1,Math.floor(Number(item.cantidad||1))),stock=Number(record.row[indexes.existencia]||0),price=Number(record.row[indexes.precio]||0),name=String(record.row[indexes.nombre]||item.id);if(qty>stock)throw new Error(`Existencia insuficiente para ${name}. Disponible: ${stock}`);subtotal+=price*qty;return{id:String(item.id),nombre:name,precio:price,cantidad:qty,total:price*qty,rowNumber:record.rowNumber,stock};});const cfg=getPublicConfig_(),shipping=subtotal>=cfg.freeShippingFrom?0:cfg.shippingCost,total=subtotal+shipping,nowDate=new Date(),now=Utilities.formatDate(nowDate,APP.TIMEZONE,'yyyy-MM-dd HH:mm:ss'),orderId='DJ-'+Utilities.formatDate(nowDate,APP.TIMEZONE,'yyyyMMdd-HHmmss')+'-'+Math.floor(Math.random()*900+100);items.forEach(item=>productsSheet.getRange(item.rowNumber,indexes.existencia+1).setValue(item.stock-item.cantidad));orders.appendRow([orderId,now,clean_(payload.nombre),clean_(payload.telefono),clean_(payload.email),clean_(payload.direccion),JSON.stringify(items.map(({rowNumber,stock,...x})=>x)),subtotal,shipping,total,'NUEVO',clean_(payload.metodoPago||'Por confirmar'),clean_(payload.notas)]);upsertClient_(payload,orderId,now,total);sendOrderEmail_(orderId,payload,items,subtotal,shipping,total);return{ok:true,pedidoId:orderId,subtotal,envio:shipping,total};}finally{lock.releaseLock();}}
function validateOrder_(p){if(!p||!Array.isArray(p.items)||!p.items.length)throw new Error('El carrito está vacío.');if(!String(p.nombre||'').trim())throw new Error('Escribe tu nombre.');if(!/^\d{10,15}$/.test(String(p.telefono||'').replace(/\D/g,'')))throw new Error('Escribe un teléfono válido de 10 a 15 dígitos.');if(!String(p.direccion||'').trim())throw new Error('Escribe la dirección de entrega.');}
function upsertClient_(payload,orderId,now,total){const sh=getSpreadsheet_().getSheetByName(APP.SHEETS.CLIENTS);if(!sh)return;const phone=String(payload.telefono||'').replace(/\D/g,''),email=clean_(payload.email).toLowerCase(),values=sh.getDataRange().getValues(),headers=values[0].map(String),idx=Object.fromEntries(headers.map((h,i)=>[h,i])),matchIndex=values.slice(1).findIndex(r=>(phone&&String(r[idx.telefono]||'').replace(/\D/g,'')===phone)||(email&&String(r[idx.email]||'').toLowerCase()===email));if(matchIndex>=0){const row=matchIndex+2;sh.getRange(row,idx.nombre+1).setValue(clean_(payload.nombre));sh.getRange(row,idx.telefono+1).setValue(phone);sh.getRange(row,idx.email+1).setValue(email);sh.getRange(row,idx.direccion+1).setValue(clean_(payload.direccion));sh.getRange(row,idx.ultimoPedido+1).setValue(now);sh.getRange(row,idx.totalPedidos+1).setValue(Number(values[matchIndex+1][idx.totalPedidos]||0)+1);sh.getRange(row,idx.totalGastado+1).setValue(Number(values[matchIndex+1][idx.totalGastado]||0)+total);}else sh.appendRow(['CL-'+Utilities.getUuid().slice(0,8).toUpperCase(),clean_(payload.nombre),phone,email,clean_(payload.direccion),now,now,1,total,'Pedido inicial: '+orderId]);}
function clean_(value){return String(value||'').trim().slice(0,1000);}
function sendOrderEmail_(id,p,items,subtotal,shipping,total){const admin=PropertiesService.getScriptProperties().getProperty(APP.ADMIN_EMAIL_PROPERTY);if(!admin)return;const rows=items.map(i=>`${i.cantidad} x ${i.nombre} — $${i.total.toFixed(2)}`).join('\n');MailApp.sendEmail({to:admin,subject:`Nuevo pedido ${id} - ${APP.NAME}`,body:`Nuevo pedido ${id}\n\nCliente: ${p.nombre}\nTeléfono: ${p.telefono}\nEmail: ${p.email||'-'}\nDirección: ${p.direccion}\nMétodo: ${p.metodoPago||'Por confirmar'}\n\n${rows}\n\nSubtotal: $${subtotal.toFixed(2)}\nEnvío: $${shipping.toFixed(2)}\nTotal: $${total.toFixed(2)}\n\nNotas: ${p.notas||'-'}`});}
